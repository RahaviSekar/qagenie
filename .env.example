GEMINI_API_KEY=your_gemini_key_from_aistudio_google_com
# Use IDs from https://ai.google.dev/gemini-api/docs/models (gemini-1.5-* names often 404 on the current API)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite
PORT=3000
# Whole Playwright process wall time (ms). Default 600000+; auto-scales with test count (floor 900000 if set).
PLAYWRIGHT_RUN_TIMEOUT_MS=900000
# Per-test timeout (ms). Default 180000. Use 300000 for flows with 2+ minute waits (e.g. company search).
PLAYWRIGHT_TEST_TIMEOUT_MS=300000
# Use visible Chrome instead of headless (helps some Cloudflare / bot-check sites)
# PLAYWRIGHT_HEADED=true
# Max POS and max NEG tests per flow run (default 3 each → ~7 tests with happy path).
FLOW_MAX_SCENARIO_TESTS_PER_KIND=3
# Skip MCP browser preflight before script generation (faster start).
# MCP_FLOW_SKIP_PREFLIGHT=true
# MCP layer (browser + playwright + optional external servers)
MCP_SCAN_EXPLORE_STEPS=10
MCP_FLOW_SKIP_PREFLIGHT=false
# Optional: JSON array of stdio MCP servers, e.g. [{"command":"npx","args":["@playwright/mcp@latest"]}]
# MCP_EXTERNAL_SERVERS=
# Optional: comma-separated hostnames allowed for http_fetch tool
# MCP_HTTP_ALLOWLIST=api.example.com
REGRESSION_BASE_URL=https://example.com
WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
